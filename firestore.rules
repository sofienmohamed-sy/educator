rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Curriculum profiles are readable by any signed-in user.
    // Writes are only allowed from the Admin SDK (Cloud Functions / seed scripts).
    match /curricula/{countryCode} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-user data: only the owner may read or write.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
