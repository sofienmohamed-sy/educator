rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Checks professor role. Only called on write paths (costs one Firestore read).
    function isProfessor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "professor";
    }

    // ── Curriculum profiles ───────────────────────────────────────────────────

    match /curricula/{countryCode} {
      allow read: if isSignedIn();
      allow write: if false; // Admin SDK only
    }

    // ── User profile + subcollections ─────────────────────────────────────────

    match /users/{uid} {
      // Top-level document holds the user profile (role, defaultCountry, etc.)
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          "role", "defaultCountry", "defaultGradeLevel",
          "preferredLanguage", "createdAt", "updatedAt"
        ])
        && request.resource.data.role in ["student", "professor"];
      allow update: if isOwner(uid)
        && request.resource.data.role in ["student", "professor"];
      allow delete: if false;

      // Problems — written by Cloud Functions only; read by owner
      match /problems/{problemId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Generated courses — written by Cloud Functions only; read by owner
      match /courses/{courseId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Generated exercises — written by Cloud Functions only; read by owner
      match /exercises/{exerciseId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Generated exams — written by Cloud Functions only; read by owner
      match /exams/{examId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Rate limit counters — never client-accessible
      match /_meta/{doc} {
        allow read, write: if false;
      }
    }

    // ── Book library ──────────────────────────────────────────────────────────

    match /books/{bookId} {
      // All signed-in users can read ready books.
      // Professors can also see their own books at any status.
      allow read: if isSignedIn() && (
        resource.data.status == "ready"
        || (isProfessor() && resource.data.uploadedBy == request.auth.uid)
      );
      // Only professors can create book metadata records (status must start as "pending").
      allow create: if isProfessor()
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.status == "pending";
      // Status updates (processing → ready/error) are done by Cloud Functions via Admin SDK.
      allow update, delete: if false;

      // Chunks are accessed only via Admin SDK in Cloud Functions.
      // No client reads or writes.
      match /chunks/{chunkId} {
        allow read, write: if false;
      }
    }

    // ── Deny everything else ──────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
